# Get this from Hygraph Studio > Project Settings > API Access > Content API
HYGRAPH_ENDPOINT=https://api-<region>.hygraph.com/v2/<project-id>/master

# Permanent Auth Token – Default stage: PUBLISHED
# Create in Hygraph Studio > Project Settings > API Access > Permanent Auth Tokens
HYGRAPH_PRODUCTION_TOKEN=

# Permanent Auth Token – Default stage: DRAFT
# Create a second token with Default Stage set to DRAFT
HYGRAPH_PREVIEW_TOKEN=

# Public env vars for Preview SDK (Click to Edit)
# Must be the regular Content API URL (not CDN) — Studio uses this to identify the project
NEXT_PUBLIC_HYGRAPH_ENDPOINT=https://api-<region>.hygraph.com/v2/<project-id>/master
NEXT_PUBLIC_HYGRAPH_STUDIO_URL=https://studio-<region>.hygraph.com

# Optional: secret for preview URL validation
HYGRAPH_PREVIEW_SECRET=

# Must match Hygraph webhook "Secret key" (gcms-signature). Same for ?secret= / Bearer if used.
# Generate e.g. openssl rand -hex 32 — never commit the real value
REVALIDATE_SECRET=

# UI locales (next-intl): English default; German at /de/...
# Edit messages/en.json and messages/de.json for copy.
