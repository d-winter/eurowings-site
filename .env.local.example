# Get this from Hygraph Studio > Project Settings > API Access > Content API
HYGRAPH_ENDPOINT=https://api-<region>.hygraph.com/v2/<project-id>/master

# Permanent Auth Token – Default stage: PUBLISHED
# Create in Hygraph Studio > Project Settings > API Access > Permanent Auth Tokens
HYGRAPH_PRODUCTION_TOKEN=

# Permanent Auth Token – Default stage: DRAFT
# Create a second token with Default Stage set to DRAFT
HYGRAPH_PREVIEW_TOKEN=

# Optional: secret for preview URL validation
HYGRAPH_PREVIEW_SECRET=
